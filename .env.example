# Ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral

# Detection thresholds
AUTO_CLOSE_THRESHOLD=40
ESCALATE_THRESHOLD=75
WASH_TRADE_WINDOW_SECONDS=30
SPOOF_CANCEL_WINDOW_SECONDS=10

# SLA (minutes)
STANDARD_SLA_MINUTES=240
ESCALATED_SLA_MINUTES=60

# Ingestion speed (seconds between trades)
INGESTION_INTERVAL_SECONDS=8
